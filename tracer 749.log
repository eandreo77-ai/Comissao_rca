    SELECT NVL(CO.CODIGOCENTROCUSTO, CO.CODCENTROCUSTO) AS CODIGOCENTROCUSTO,                         
          CASE WHEN (SELECT COUNT(L.CODIGON) QTD                                                      
                       FROM PCLIB L                                                                   
                      WHERE L.CODTABELA = 10                                                          
                        AND L.CODIGOA = CC.CODIGOCENTROCUSTO                                          
                        AND L.CODFUNC = :CODFUNC                                                      
                        AND ROWNUM = 1) >= 1 THEN 'S'                                               
               ELSE 'N'                                                                             
          END CCTEMPERMISSAO_PCLIB                                                                    
     FROM PCCONTACENTROCUSTO CO, PCCENTROCUSTO CC                                                     
    WHERE NVL(CO.CODIGOCENTROCUSTO, CO.CODCENTROCUSTO) = NVL(CC.CODIGOCENTROCUSTO, CC.CODCENTROCUSTO) 
      AND CO.CODCONTA = :CODCONTA                                                                     
      AND NVL(CC.ATIVO, 'S') = 'S'                                                                
      AND NVL(CC.RECEBE_LANCTO, 'S') = 'S'                                                        
    ORDER BY NVL(CO.CODIGOCENTROCUSTO, CO.CODCENTROCUSTO)
