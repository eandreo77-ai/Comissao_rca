Time: 16:00:28 Execute     [231991584]  OCIStmtExecute                 session #3
    SELECT F.CODIGO,
           F.RAZAOSOCIAL,
           F.FANTASIA,
           F.CODIGO || ' - ' || F.RAZAOSOCIAL FILIAL,
           F.IE,
           F.CGC,
           F.TELEFONE,
           F.ENDERECO,
           F.EMAIL,
           NVL(F.NUMERO2, TO_CHAR(F.NUMERO)) NUMERO,
           F.BAIRRO,
           F.CIDADE,
           F.UF,
           F.CEP,
           F.CONTATO,
           F.CODMUN CODIBGE,
           F.NUMIDF,
           F.CODDOCNFC,
           F.UTILIZANFE,
           F.INDUSTRIA,
           NVL(F.TIPOMONTAGEM, 'R') TIPOMONTAGEM,
           F.INTEGRADORAWMS
      FROM PCFILIAL F
     WHERE (((F.CODIGO <> '99') AND EXISTS
            (SELECT CODIGOA
                FROM PCLIB
               WHERE CODTABELA = 1
                 AND CODFUNC = 2245
                 AND CODIGOA = '99')) OR
           ((F.CODIGO IN (SELECT CODIGOA
                             FROM PCLIB
                            WHERE CODTABELA = 1
                              AND CODFUNC = 2245)) AND NOT EXISTS
            (SELECT CODIGOA
                FROM PCLIB
               WHERE CODTABELA = 1
                 AND CODFUNC = 2245
                 AND CODIGOA = '99')))
     AND UPPER( F.CODIGO  )= UPPER( :PARAM1 ) ORDER BY F.CODIGO
