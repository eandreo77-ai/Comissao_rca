# =============================================================================
# Comissao RCA — variáveis de ambiente
# Copie para .env e preencha os valores reais
# NUNCA COMMITAR .env (já está no .gitignore)
# =============================================================================

# ── Streamlit ───────────────────────────────────────────────────────────────
APP_PORT=8501
APP_BASE_URL_PATH=comissao
APP_SECRET=trocar-por-string-aleatoria-32+chars

# ── Oracle (WinThor) ────────────────────────────────────────────────────────
# DSN no formato Easy Connect ou TNS completo
ORACLE_USER=TESTE
ORACLE_PASSWORD=TESTE
ORACLE_DSN=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=192.168.0.172)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=BDTESTE)))
# Caminho do Instant Client dentro do container
ORACLE_INSTANTCLIENT_DIR=/opt/instantclient

# ── MariaDB ─────────────────────────────────────────────────────────────────
# Host = nome do serviço no docker-compose (não usar 'localhost' aqui)
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DATABASE=comissao_rca
MARIADB_USER=comissao
MARIADB_PASSWORD=trocar-senha-forte-aqui
# Senha do root (só usado pelo container do MariaDB para o bootstrap)
MARIADB_ROOT_PASSWORD=trocar-senha-root-forte

# ── Valores fixos do negócio (fallback se a tabela 'configuracoes' não existir) ──
CODCONTA_PADRAO=100010
CODFILIAL_PADRAO=1
TIPOSERVICO=99
