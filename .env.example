# =============================================================================
# Comissao RCA — variáveis de ambiente (template)
# Copie para .env e preencha os valores reais.
# NUNCA COMMITAR .env (já está no .gitignore).
# =============================================================================

# ── Streamlit ───────────────────────────────────────────────────────────────
APP_PORT=8502
APP_BASE_URL_PATH=comissao
APP_SECRET=trocar-por-string-aleatoria-32+chars

# ── Oracle (WinThor) ────────────────────────────────────────────────────────
# DSN no formato TNS completo (Oracle 11g)
ORACLE_USER=TESTE
ORACLE_PASSWORD=TESTE
ORACLE_DSN=(DESCRIPTION=(ADDRESS=(PROTOCOL=TCP)(HOST=192.168.0.172)(PORT=1521))(CONNECT_DATA=(SERVICE_NAME=BDTESTE)))
# Path do Instant Client. No servidor é montado via volume em /opt/instantclient.
# Em dev local Windows: C:\instantclient-basic\instantclient_23_8
ORACLE_INSTANTCLIENT_DIR=/opt/instantclient

# ── MariaDB ─────────────────────────────────────────────────────────────────
# No servidor: usar 127.0.0.1 (network_mode: host acessa o MariaDB nativo)
# Em dev local Windows: localhost (precisa MariaDB rodando) OU placeholder se for usar lazy
MARIADB_HOST=127.0.0.1
MARIADB_PORT=3306
MARIADB_DATABASE=comissao_rca
MARIADB_USER=comissao
MARIADB_PASSWORD=trocar-senha-forte-aqui

# ── Valores fixos do negócio (default; só preencher se quiser sobrescrever) ─
# CODCONTA_PADRAO=100010
# CODFILIAL_PADRAO=1
# TIPOSERVICO=99
